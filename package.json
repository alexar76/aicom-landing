{
  "name": "aicom-landing",
  "version": "0.1.1",
  "description": "MIT — one prompt → self-contained HTML landing in ~30–60s (Architect + Developer, 20 style presets). Part of the AI-Factory ecosystem.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aicom-landing": "./cli.mjs",
    "aicom-landing-serve": "./preview-server.mjs"
  },
  "scripts": {
    "serve": "node preview-server.mjs",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "demo-gif": "node scripts/capture-demo-gif.mjs",
    "test": "node cli.mjs --help && node cli.mjs --list-styles",
    "prepublishOnly": "npm test"
  },
  "files": [
    "cli.mjs",
    "preview-server.mjs",
    "lib",
    "llm",
    "public",
    "styles",
    "docs",
    "Dockerfile",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "keywords": [
    "ai-landing-page-generator",
    "landing-page-builder",
    "ai-factory-ecosystem",
    "aicom-landing",
    "mit",
    "self-hosted"
  ],
  "homepage": "https://magic-ai-factory.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexar76/aicom-landing"
  },
  "devDependencies": {
    "gifenc": "^1.0.3",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5"
  }
}
